{
  "name": "generator-readteractive",
  "version": "1.0.0",
  "description": "A yeoman generator for scaffolding Readteractive interactive books.",
  "homepage": "https://github.com/Carleslc/readteractive-generator",
  "author": {
    "name": "Carlos Lázaro Costa",
    "email": "lazaro.costa.carles@gmail.com",
    "url": "https://carleslc.me"
  },
  "files": [
    "generators",
    "utils"
  ],
  "main": "generators/index.js",
  "keywords": [
    "yeoman-generator",
    "book",
    "writing",
    "interactive",
    "pandoc",
    "storytelling",
    "storybook",
    "e-book"
  ],
  "devDependencies": {
    "yeoman-test": "^5.1.0",
    "yeoman-assert": "^3.1.1",
    "eslint": "^8.57.1",
    "prettier": "^3.8.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-config-xo": "^0.44.0",
    "jest": "^29.7.0"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "iso-639-1": "^3.1.5",
    "js-yaml": "^4.1.1",
    "yeoman-generator": "^5.10.0",
    "yosay": "^2.0.2"
  },
  "jest": {
    "testEnvironment": "node"
  },
  "scripts": {
    "prepare": "husky",
    "pretest": "eslint .",
    "test": "jest"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "eslintConfig": {
    "extends": [
      "xo",
      "prettier"
    ],
    "env": {
      "jest": true,
      "node": true
    },
    "rules": {
      "prettier/prettier": [
        "error",
        {
          "singleQuote": true,
          "printWidth": 90
        }
      ]
    },
    "plugins": [
      "prettier"
    ]
  },
  "repository": "https://github.com/Carleslc/readteractive-generator.git",
  "license": "MIT"
}
